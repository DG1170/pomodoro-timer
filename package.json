{
  "name": "pomodoro-timer",
  "version": "0.0.1",
  "description": "桌面番茄钟",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.js",
    "build": "electron-builder",
    "node22": "/tmp/node-v22-install/node-v22.14.0-win-x64/node.exe"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "alpinejs": "^3.15.12"
  },
  "build": {
    "appId": "com.pomodoro.timer",
    "productName": "番茄钟",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "node_modules/alpinejs/**"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
